# ============================================================
# DEV-ONLY DEFAULTS — NEVER USE THESE VALUES IN PRODUCTION
# ============================================================
# All values in this file are insecure development defaults.
# Before deploying to any environment:
#   - Replace POSTGRES_PASSWORD with a strong random password
#   - Replace WEBHOOK_SECRET with a securely generated secret:
#       python -c "import secrets; print(secrets.token_hex(32))"
#   - Set SKIP_WEBHOOK_VERIFICATION=false (or remove it entirely)
#   - Set ENVIRONMENT=production
# In production, load secrets from Azure Key Vault via Managed Identity.
# ============================================================
POSTGRES_USER=fixpoint
POSTGRES_PASSWORD=fixpoint  # CHANGE IN PRODUCTION
POSTGRES_DB=fixpoint
DATABASE_URL=postgresql+psycopg://fixpoint:fixpoint@postgres:5432/fixpoint  # CHANGE IN PRODUCTION
REDIS_URL=redis://redis:6379/0
WEBHOOK_SECRET=devsecret  # CHANGE IN PRODUCTION — use python -c "import secrets; print(secrets.token_hex(32))"
FIXPOINT_MODE=warn
ENVIRONMENT=development
SKIP_WEBHOOK_VERIFICATION=true  # SET TO false IN PRODUCTION
ENGINE_MODE=local
ENGINE_REPO_PATH=/tmp/fixpoint-e2e/demo
ENGINE_BASE_REF=main
ENGINE_HEAD_REF=feature
NEXT_PUBLIC_API_BASE_URL=http://api:8000
ENGINE_VERSION=
ENABLE_ENGINE=false
LOCAL_REPO_PATH=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
